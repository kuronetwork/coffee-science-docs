---
/**
 * 文章頁版型。
 *
 * 桌面三欄：[Sidebar 240px] [內容主區 720px] [TOC 200px]
 * 手機（< 960px）：單欄 + 頂部「目錄」<details> 收納 sidebar 與 TOC。
 *
 * 提供區塊：
 *   - breadcrumb
 *   - h1 + ProgressTag
 *   - metadata（更新日期、預估閱讀、SCA 標記）
 *   - <slot /> 文章內容
 *   - 上一篇 / 下一篇
 *   - 回到頂部
 */
import type { MarkdownHeading } from 'astro';
import BaseLayout from './BaseLayout.astro';
import Sidebar from '../components/Sidebar.astro';
import TableOfContents from '../components/TableOfContents.astro';
import ProgressTag from '../components/ProgressTag.astro';

import { findSection } from '../content/sections';
import { getSiblings } from '../utils/content';
import { url } from '../utils/url';
import '../styles/typography.css';

interface Props {
  title: string;
  description?: string;
  collection: string;
  slug: string;
  updated: Date;
  progress: 'drafting' | 'reviewing' | 'done';
  readingTimeMinutes: number;
  sca?: 'barista' | 'brewing' | 'sensory' | 'roasting' | 'green' | null;
  headings: MarkdownHeading[];
}

const {
  title,
  description,
  collection,
  slug,
  updated,
  progress,
  readingTimeMinutes,
  sca,
  headings,
} = Astro.props;

const section = findSection(collection);

const { prev, next } = await getSiblings(collection as any, slug);

const updatedISO = updated.toISOString().slice(0, 10);

const scaLabelMap = {
  barista: 'SCA Barista',
  brewing: 'SCA Brewing',
  sensory: 'SCA Sensory',
  roasting: 'SCA Roasting',
  green: 'SCA Green',
} as const;
---

<BaseLayout
  title={title}
  description={description}
  ogType="article"
  datePublished={updated}
  dateModified={updated}
>
  <div class="doc-shell">
    <aside class="doc-sidebar-area">
      <Sidebar currentCollection={collection} currentSlug={slug} />
    </aside>

    <article class="doc-article">
      <nav class="doc-breadcrumb" aria-label="麵包屑">
        <a href={url('/')}>首頁</a>
        <span aria-hidden="true">/</span>
        <a href={url(`/${collection}`)}>{section?.title ?? collection}</a>
        <span aria-hidden="true">/</span>
        <span class="doc-breadcrumb__current">{title}</span>
      </nav>

      <header class="doc-header">
        <h1 class="doc-title">
          {title}
          <ProgressTag progress={progress} />
        </h1>

        <p class="doc-meta">
          <span>更新：<time datetime={updatedISO}>{updatedISO}</time></span>
          <span>預估閱讀 {readingTimeMinutes} 分鐘</span>
          {sca && <span>{scaLabelMap[sca]}</span>}
        </p>
      </header>

      <details class="doc-mobile-toc" aria-label="本頁目錄">
        <summary>本頁目錄</summary>
        <TableOfContents headings={headings} />
      </details>

      <div class="prose">
        <slot />
      </div>

      <nav class="doc-prev-next" aria-label="同章節導覽">
        <div class="doc-prev-next__col">
          {
            prev && (
              <a href={url(`/${collection}/${prev.id}`)}>
                <span class="doc-prev-next__label">上一篇</span>
                <span class="doc-prev-next__title">{prev.data.title}</span>
              </a>
            )
          }
        </div>
        <div class="doc-prev-next__col doc-prev-next__col--right">
          {
            next && (
              <a href={url(`/${collection}/${next.id}`)}>
                <span class="doc-prev-next__label">下一篇</span>
                <span class="doc-prev-next__title">{next.data.title}</span>
              </a>
            )
          }
        </div>
      </nav>

      <footer class="doc-footer">
        <a href="#main" class="doc-footer__top">回到頂部</a>
      </footer>
    </article>

    <aside class="doc-toc-area">
      <TableOfContents headings={headings} />
    </aside>
  </div>
</BaseLayout>

<script>
  /**
   * 文章內若出現互動元件，動態載入對應腳本。
   * 沒用到的文章不會付出 JS 成本（hydration directive 規則）。
   */
  function maybeLoadInteractive() {
    if (document.querySelector('extraction-calc, brew-ratio-calc')) {
      import('../scripts/calculators.ts');
    }
    if (document.querySelector('brew-method-compare')) {
      import('../scripts/brew-method-compare.ts');
    }
    if (document.querySelector('brew-ratio-visualizer')) {
      import('../scripts/brew-ratio-visualizer.ts');
    }
    if (document.querySelector('flavor-wheel')) {
      import('../scripts/flavor-wheel.ts');
    }
    if (document.querySelector('control-chart')) {
      import('../scripts/control-chart.ts');
    }
    if (document.querySelector('brew-ratio-slider')) {
      import('../scripts/brew-ratio-slider.ts');
    }
    if (document.querySelector('cherry-anatomy')) {
      import('../scripts/cherry-anatomy.ts');
    }
    if (document.querySelector('channeling-flow')) {
      import('../scripts/channeling-flow.ts');
    }
    if (document.querySelector('espresso-debug-tree')) {
      import('../scripts/espresso-debug-tree.ts');
    }
    if (document.querySelector('extraction-timeline')) {
      import('../scripts/extraction-timeline.ts');
    }
    if (document.querySelector('roast-curve')) {
      import('../scripts/roast-curve.ts');
    }
    if (document.querySelector('roast-level-slider')) {
      import('../scripts/roast-level-slider.ts');
    }
    if (document.querySelector('bloom-pre-infusion-timeline')) {
      import('../scripts/bloom-pre-infusion-timeline.ts');
    }
    if (document.querySelector('water-chemistry-2d')) {
      import('../scripts/water-chemistry-2d.ts');
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', maybeLoadInteractive, { once: true });
  } else {
    maybeLoadInteractive();
  }
</script>

<style>
  .doc-shell {
    display: grid;
    grid-template-columns: 240px minmax(0, 1fr) 200px;
    gap: var(--space-12);
    align-items: flex-start;
  }

  /* sidebar 與 toc 在桌面要 sticky */
  .doc-sidebar-area {
    position: sticky;
    top: var(--space-8);
    max-height: calc(100vh - var(--space-16));
    overflow-y: auto;
    padding-right: var(--space-2);
  }

  .doc-toc-area {
    position: sticky;
    top: var(--space-8);
    max-height: calc(100vh - var(--space-16));
    overflow-y: auto;
  }

  .doc-article {
    max-width: var(--content-width);
    min-width: 0;
  }

  /* === 麵包屑 === */
  .doc-breadcrumb {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
    margin-bottom: var(--space-6);
    flex-wrap: wrap;
  }

  .doc-breadcrumb a {
    color: var(--color-text-muted);
    text-decoration: none;
  }

  .doc-breadcrumb a:hover {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 0.18em;
  }

  .doc-breadcrumb__current {
    color: var(--color-text);
  }

  /* === 文章標題與 metadata === */
  .doc-header {
    margin-bottom: var(--space-8);
  }

  .doc-title {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: var(--font-size-3xl);
    letter-spacing: -0.005em;
    line-height: 1.3;
    margin: 0 0 var(--space-3);
  }

  .doc-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    margin: 0;
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
  }

  /* === 手機版目錄（桌面隱藏） === */
  .doc-mobile-toc {
    display: none;
    margin: 0 0 var(--space-8);
    padding: var(--space-4);
    border: var(--border-thin);
    border-radius: var(--radius-md);
    background: var(--color-bg-elevated);
  }

  .doc-mobile-toc summary {
    cursor: pointer;
    font-size: var(--font-size-sm);
    color: var(--color-text);
  }

  /* === 上一篇 / 下一篇 === */
  .doc-prev-next {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-6);
    margin-top: var(--space-16);
    padding-top: var(--space-8);
    border-top: var(--border-thin);
  }

  .doc-prev-next__col a {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    color: var(--color-text);
    text-decoration: none;
  }

  .doc-prev-next__col--right {
    text-align: right;
  }

  .doc-prev-next__col--right a {
    align-items: flex-end;
  }

  .doc-prev-next__label {
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    color: var(--color-text-subtle);
  }

  .doc-prev-next__title {
    font-size: var(--font-size-base);
    color: var(--color-text-muted);
    transition: color var(--transition-fast);
  }

  .doc-prev-next__col a:hover .doc-prev-next__title {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 0.18em;
  }

  /* === 文章 footer === */
  .doc-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: var(--space-8);
    padding-top: var(--space-6);
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  .doc-footer__top {
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
    text-decoration: underline;
    text-decoration-color: var(--color-border-strong);
    text-underline-offset: 0.18em;
  }

  .doc-footer__top:hover {
    color: var(--color-accent);
  }

  /* === 平板 / 中型螢幕：把 TOC 收進文章上方 === */
  @media (max-width: 1100px) {
    .doc-shell {
      grid-template-columns: 220px minmax(0, 1fr);
    }

    .doc-toc-area {
      display: none;
    }

    .doc-mobile-toc {
      display: block;
    }
  }

  /* === 手機版佈局 === */
  @media (max-width: 768px) {
    .doc-shell {
      grid-template-columns: 1fr;
    }

    .doc-sidebar-area {
      display: none;
    }
  }
</style>
